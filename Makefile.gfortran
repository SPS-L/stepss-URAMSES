#
# Makefile for RAMSES using gfortran (Linux only)
# For Windows builds, use Visual Studio with URAMSES.sln
#
# Author: Sustainable Power Systems Lab (SPS-L)
# Web: https://sps-lab.org
# Contact: info@sps-lab.org
# Last edited: January 2026
#

# ============================================================================
# Configuration
# ============================================================================

# Compiler and tools
FC = gfortran
AR = ar
RM = rm -f
RMDIR = rm -rf
MKDIR = mkdir -p

# Directories
SRC_DIR = src
MY_MODELS_DIR = my_models
MOD_DIR = modules_lin
OUT_DIR = Release_gnu_l
OBJ_DIR = $(OUT_DIR)/obj

# Output files
TARGET_SO = ramses.so
TARGET_EXE = dynsim

# Compiler flags
# -O2: Optimization level 2
# -cpp: Enable C preprocessor
# -fopenmp: Enable OpenMP support
# -fPIC: Position Independent Code (required for shared libraries)
# -DDLL: Define DLL preprocessor macro (matches Windows build)
# -ffree-line-length-none: No line length limit for free-form Fortran
# -ffree-form: Use free-form source layout
FFLAGS = -O2 -cpp -fopenmp -fPIC -DDLL \
         -ffree-line-length-none -ffree-form \
         -I$(MOD_DIR)

# Linker flags for shared library
LDFLAGS_SO = -shared -fopenmp

# Linker flags for executable
LDFLAGS_EXE = -fopenmp

# Libraries
# Link against pre-compiled libramses.a and OpenBLAS
LIBS = -L$(MOD_DIR) -lramses -lopenblas 

# ============================================================================
# Source files
# ============================================================================

# Source files from src/ (excluding main.f90 which is for executable only)
SRC_FILES = $(filter-out $(SRC_DIR)/main.f90, $(wildcard $(SRC_DIR)/*.f90))

# Source files from my_models/ (only .f90 files)
MY_MODEL_FILES = $(wildcard $(MY_MODELS_DIR)/*.f90)

# All source files for shared library
SRCS = $(SRC_FILES) $(MY_MODEL_FILES)

# Object files for shared library
OBJS = $(addprefix $(OBJ_DIR)/, $(notdir $(SRCS:.f90=.o)))

# Object files for executable (includes main.o)
OBJS_EXE = $(OBJS) $(OBJ_DIR)/main.o

# ============================================================================
# Check for Linux
# ============================================================================

ifneq ($(shell uname -s),Linux)
    $(error This Makefile is for Linux only. For Windows, use Visual Studio with URAMSES.sln)
endif

# ============================================================================
# Targets
# ============================================================================

.PHONY: all dll exe clean check-deps help

# Default target - build both shared library and executable
all: check-deps $(OUT_DIR)/$(TARGET_SO) $(OUT_DIR)/$(TARGET_EXE)

# Build only shared library
dll: check-deps $(OUT_DIR)/$(TARGET_SO)

# Build only executable
exe: check-deps $(OUT_DIR)/$(TARGET_EXE)

# Help target
help:
	@echo "RAMSES Linux Build System (gfortran)"
	@echo "====================================="
	@echo ""
	@echo "Usage: make -f Makefile.gfortran [target]"
	@echo ""
	@echo "Targets:"
	@echo "  all         - Build both ramses.so and dynsim (default)"
	@echo "  dll         - Build only ramses.so (shared library)"
	@echo "  exe         - Build only dynsim (executable)"
	@echo "  clean       - Remove all build artifacts"
	@echo "  check-deps  - Verify required dependencies"
	@echo "  help        - Show this help message"
	@echo ""
	@echo "Output:"
	@echo "  $(OUT_DIR)/$(TARGET_SO)   - Shared library for PyRAMSES"
	@echo "  $(OUT_DIR)/$(TARGET_EXE)  - Standalone executable"
	@echo ""
	@echo "For Windows builds, use Visual Studio with URAMSES.sln"

# Check dependencies
check-deps:
	@echo "Checking dependencies..."
	@echo ""
	@echo "Checking for gfortran..."
	@if ! command -v gfortran > /dev/null 2>&1; then \
		echo "ERROR: gfortran not found. Please install gfortran:"; \
		echo "  Ubuntu/Debian: sudo apt install gfortran"; \
		echo "  Fedora/RHEL:   sudo dnf install gcc-gfortran"; \
		echo "  Arch Linux:    sudo pacman -S gcc-fortran"; \
		exit 1; \
	else \
		echo "  Found: $$(gfortran --version | head -n1)"; \
	fi
	@echo ""
	@echo "Checking for pre-compiled modules..."
	@if [ ! -d "$(MOD_DIR)" ]; then \
		echo "ERROR: Module directory '$(MOD_DIR)' not found."; \
		exit 1; \
	fi
	@if [ ! -f "$(MOD_DIR)/libramses.a" ]; then \
		echo "ERROR: Pre-compiled library '$(MOD_DIR)/libramses.a' not found."; \
		exit 1; \
	fi
	@echo "  Found: $(MOD_DIR)/libramses.a"
	@MOD_COUNT=$$(ls -1 $(MOD_DIR)/*.mod 2>/dev/null | wc -l); \
	echo "  Found: $$MOD_COUNT module files in $(MOD_DIR)/"
	@echo ""
	@echo "All dependencies satisfied."
	@echo ""

# ============================================================================
# Build rules
# ============================================================================

# Create output directory
$(OUT_DIR):
	$(MKDIR) $(OUT_DIR)

# Create object directory
$(OBJ_DIR): | $(OUT_DIR)
	$(MKDIR) $(OBJ_DIR)

# Build shared library
$(OUT_DIR)/$(TARGET_SO): $(OBJS) | $(OUT_DIR)
	@echo ""
	@echo "Linking $(TARGET_SO)..."
	$(FC) $(LDFLAGS_SO) -o $@ $(OBJS) $(LIBS)
	@echo ""
	@echo "Shared library built: $@"

# Build executable
$(OUT_DIR)/$(TARGET_EXE): $(OBJS_EXE) | $(OUT_DIR)
	@echo ""
	@echo "Linking $(TARGET_EXE)..."
	$(FC) $(LDFLAGS_EXE) -o $@ $(OBJS_EXE) $(LIBS)
	@echo ""
	@echo "Executable built: $@"

# Compile source files from src/
$(OBJ_DIR)/%.o: $(SRC_DIR)/%.f90 | $(OBJ_DIR)
	@echo "Compiling $<..."
	$(FC) $(FFLAGS) -c $< -o $@ -J$(OBJ_DIR)

# Compile source files from my_models/
$(OBJ_DIR)/%.o: $(MY_MODELS_DIR)/%.f90 | $(OBJ_DIR)
	@echo "Compiling $<..."
	$(FC) $(FFLAGS) -c $< -o $@ -J$(OBJ_DIR)

# ============================================================================
# Clean
# ============================================================================

clean:
	@echo "Cleaning build artifacts..."
	$(RMDIR) $(OUT_DIR)
	@echo "Clean complete."

# ============================================================================
# File dependencies
# ============================================================================

# FUNCTIONS_IN_MODELS must be compiled before model files that use it
$(OBJ_DIR)/exc_ENTSOE_lim.o: $(OBJ_DIR)/FUNCTIONS_IN_MODELS.o
$(OBJ_DIR)/exc_GENERIC3.o: $(OBJ_DIR)/FUNCTIONS_IN_MODELS.o
$(OBJ_DIR)/exc_GENERIC4.o: $(OBJ_DIR)/FUNCTIONS_IN_MODELS.o
$(OBJ_DIR)/exc_ST1A.o: $(OBJ_DIR)/FUNCTIONS_IN_MODELS.o
$(OBJ_DIR)/inj_AIR_COND1_mod.o: $(OBJ_DIR)/FUNCTIONS_IN_MODELS.o
$(OBJ_DIR)/tor_ENTSOE_simp.o: $(OBJ_DIR)/FUNCTIONS_IN_MODELS.o

# usr_*_models files depend on their respective model files
$(OBJ_DIR)/usr_exc_models.o: $(OBJ_DIR)/exc_ENTSOE_lim.o $(OBJ_DIR)/exc_GENERIC3.o $(OBJ_DIR)/exc_GENERIC4.o $(OBJ_DIR)/exc_ST1A.o
$(OBJ_DIR)/usr_inj_models.o: $(OBJ_DIR)/inj_AIR_COND1_mod.o
$(OBJ_DIR)/usr_tor_models.o: $(OBJ_DIR)/tor_ENTSOE_simp.o

# c_interface depends on usr_*_models
$(OBJ_DIR)/c_interface.o: $(OBJ_DIR)/usr_exc_models.o $(OBJ_DIR)/usr_inj_models.o $(OBJ_DIR)/usr_tor_models.o $(OBJ_DIR)/usr_twop_models.o $(OBJ_DIR)/usr_dctl_models.o

# main.o depends on c_interface (for executable)
$(OBJ_DIR)/main.o: $(OBJ_DIR)/c_interface.o
